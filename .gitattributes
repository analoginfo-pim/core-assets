# Force LF line endings for all text files regardless of contributor
# platform / git autocrlf setting. Without this, a Windows clone with
# the installer-default `core.autocrlf=true` rewrites every checkout
# to CRLF, then `cargo fmt` writes LF, then the next git operation
# wants to convert back to CRLF — producing perpetual whole-file
# diff churn (every commit looks like it touched every line).
* text=auto eol=lf

# Common binary file types — never convert line endings, never diff as text.
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.icns binary
*.bmp binary
*.webp binary
*.ttf binary
*.otf binary
*.woff binary
*.woff2 binary
*.eot binary
*.exe binary
*.dll binary
*.pdb binary
*.so binary
*.dylib binary
*.a binary
*.lib binary
*.zip binary
*.tar binary
*.tar.gz binary
*.tgz binary
*.gz binary
*.bz2 binary
*.xz binary
*.7z binary
*.pdf binary
*.snap binary
